# Tally AI Engine の WebSocket ポート (任意、デフォルト 3322)
# 4000/4001/5050 等は他プロジェクトと衝突しがちなので避ける。
AI_ENGINE_PORT=3322

# フロントエンドが AI Engine に接続する URL (任意、デフォルト ws://localhost:3322)
# NEXT_PUBLIC_AI_ENGINE_URL=ws://localhost:3322

# プロジェクトデータの保存先 (開発用)
# 実運用では対象リポジトリ配下の .tally/ を使う
TALLY_WORKSPACE=./workspace

# Claude Agent SDK の認証 (ADR-0006)
# 通常は `claude` CLI (Claude Code) で `claude login` 済みのトークンを暗黙利用するため設定不要。
# CI 等の非対話環境で明示的に指定したい場合のみ以下のいずれかを設定する:
# ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=

# SDK bundled native binary が OS/libc と合わない (例: Alpine/musl 版が glibc 環境に入る)
# ときは system の claude CLI を指定する。which claude で出たパス。
# CLAUDE_CODE_PATH=/home/you/.local/bin/claude
