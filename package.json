{
  "name": "tally",
  "version": "0.0.1",
  "private": true,
  "description": "既存システムの機能追加を、視覚的に要件定義するためのAIネイティブな思考環境",
  "author": "西立野 (Ignission)",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
