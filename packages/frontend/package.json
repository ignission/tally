{
  "name": "@tally/frontend",
  "version": "0.0.1",
  "private": true,
  "description": "Tally のフロントエンド (Next.js 16 App Router + React Flow キャンバス)",
  "scripts": {
    "dev": "next dev -p ${PORT:-3321}",
    "build": "next build",
    "start": "next start -p ${PORT:-3321}",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tally/ai-engine": "workspace:*",
    "@tally/core": "workspace:*",
    "@tally/storage": "workspace:*",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "dompurify": "^3.4.2",
    "mermaid": "^11.14.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
